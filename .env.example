OPENAI_API_KEY=
STT_PROVIDER=openai
LLM_PROVIDER=openai
TTS_PROVIDER=openai
OPENAI_STT_MODEL=gpt-realtime-whisper
OPENAI_STT_LANGUAGE=en
OPENAI_STT_DELAY=low
OPENAI_LLM_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/voice_lab
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
BILLING_PLATFORM_RATE_PER_MINUTE_USD=0.05
BILLING_PRICING_VERSION=openai-2026-06-15+voicemesh-lab-v1
BILLING_USAGE_SETTLE_SECONDS=3
KAFKA_CONSUMER_BATCH_SIZE=100
KAFKA_CONSUMER_BATCH_TIMEOUT_MS=500

BACKPRESSURE_HIGH_WATERMARK=10
BACKPRESSURE_LOW_WATERMARK=3
TURN_TIMEOUT_SECONDS=30
VAD_ENERGY_THRESHOLD=0.018
VAD_SILENCE_MS=700

FAILURE_INJECTION_ENABLED=false
INJECT_TTS_DELAY_MS=0
INJECT_LLM_DELAY_MS=0
INJECT_STT_DELAY_MS=0
INJECT_PROVIDER_FAILURE=false
INJECT_POSTGRES_FAILURE=false
INJECT_STAGE_TIMEOUT=false

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

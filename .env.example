OPENAI_API_KEY=
STT_PROVIDER=openai
LLM_PROVIDER=openai
TTS_PROVIDER=openai
OPENAI_STT_MODEL=gpt-realtime-whisper
OPENAI_STT_LANGUAGE=en
OPENAI_STT_DELAY=low
OPENAI_LLM_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/voice_lab
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
BILLING_PLATFORM_RATE_PER_MINUTE_USD=0.05
BILLING_PRICING_VERSION=openai-2026-06-15+voicemesh-lab-v1
BILLING_USAGE_SETTLE_SECONDS=3
KAFKA_CONSUMER_BATCH_SIZE=100
KAFKA_CONSUMER_BATCH_TIMEOUT_MS=500

BACKPRESSURE_HIGH_WATERMARK=10
BACKPRESSURE_LOW_WATERMARK=3
FLOW_QUEUE_MAX_ITEMS=128
SPEECH_CHARS_PER_SECOND=14.0
LLM_TO_TTS_LOW_WATERMARK_SPEAK_AHEAD_MS=300
LLM_TO_TTS_HIGH_WATERMARK_SPEAK_AHEAD_MS=1200
LLM_TO_TTS_HARD_LIMIT_SPEAK_AHEAD_MS=2500
TTS_TO_TRANSPORT_LOW_WATERMARK_AUDIO_MS=300
TTS_TO_TRANSPORT_HIGH_WATERMARK_AUDIO_MS=1200
TTS_TO_TRANSPORT_HARD_LIMIT_AUDIO_MS=2500
BACKPRESSURE_HARD_LIMIT_POLICY=cancel_response
TTS_OUTPUT_SAMPLE_RATE=24000
TURN_TIMEOUT_SECONDS=30
VAD_PROVIDER=webrtc
WEBRTC_VAD_MODE=2
VAD_SAMPLE_RATE=16000
VAD_FRAME_MS=20
VAD_MIN_SPEECH_MS=200
VAD_END_SILENCE_MS=700
VAD_SPEECH_PAD_MS=150
VAD_MIN_TURN_AUDIO_MS=300
VAD_MIN_SPEECH_FRAME_RATIO=0.60
VAD_MIN_TRANSCRIBED_TURN_AUDIO_MS=700
VAD_ENABLE_BROWSER_NOISE_SUPPRESSION=true
BARGE_IN_CONFIRMATION_MS=200
BARGE_IN_MIN_SPEECH_FRAMES=3
BARGE_IN_MIN_SPEECH_RATIO=0.60
BARGE_IN_CANDIDATE_RETENTION_MS=1200
BARGE_IN_BACKCHANNEL_POLICY=medium
BARGE_IN_INTERRUPTION_SENSITIVITY=medium
BARGE_IN_BACKEND_ECHO_GRACE_MS=600
BARGE_IN_BACKEND_CONFIRMATION_MS=350
BARGE_IN_BACKEND_MIN_SPEECH_RATIO=0.75
VAD_ENERGY_THRESHOLD=0.018
ENERGY_VAD_ADAPTIVE_NOISE_FLOOR=true
ENERGY_VAD_NOISE_MULTIPLIER=3.0
ENERGY_VAD_NOISE_UPDATE_ALPHA=0.05

FAILURE_INJECTION_ENABLED=false
INJECT_TTS_DELAY_MS=0
INJECT_LLM_DELAY_MS=0
INJECT_STT_DELAY_MS=0
INJECT_PROVIDER_FAILURE=false
INJECT_POSTGRES_FAILURE=false
INJECT_STAGE_TIMEOUT=false

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

    {"id": 1, "type": "text", "title": "Scope", "options": {"content": "Operational billing and webhook health only. Long-range cost analytics are deferred to future ClickHouse-backed dashboards.", "mode": "markdown"}, "gridPos": {"h": 3, "w": 24, "x": 0, "y": 0}},
    {"id": 2, "type": "timeseries", "title": "Billing workflows started/completed/failed", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum by (workflow_type, status) (increase(voicemesh_temporal_workflows_total{workflow_type=~\"BillingFinalizationWorkflow|BillingAdjustmentWorkflow\"}[5m]))", "legendFormat": "{{workflow_type}} {{status}}"}], "gridPos": {"h": 8, "w": 12, "x": 0, "y": 3}},
    {"id": 3, "type": "timeseries", "title": "Billing finalization latency p50 / p95", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "histogram_quantile(0.50, sum by (le, status) (rate(voicemesh_billing_finalization_duration_seconds_bucket[5m])))", "legendFormat": "p50 {{status}}"}, {"expr": "histogram_quantile(0.95, sum by (le, status) (rate(voicemesh_billing_finalization_duration_seconds_bucket[5m])))", "legendFormat": "p95 {{status}}"}], "gridPos": {"h": 8, "w": 12, "x": 12, "y": 3}},

    {"id": 5, "type": "timeseries", "title": "Billing adjustment workflows", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum by (reason) (increase(voicemesh_billing_adjustments_total[5m]))", "legendFormat": "{{reason}}"}], "gridPos": {"h": 8, "w": 12, "x": 12, "y": 11}},
    {"id": 6, "type": "timeseries", "title": "Webhook requested/delivered/failed state transitions", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum by (status) (increase(voicemesh_webhook_deliveries_total[5m]))", "legendFormat": "{{status}}"}], "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19}},

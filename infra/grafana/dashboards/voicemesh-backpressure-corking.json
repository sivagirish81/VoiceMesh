{
  "annotations": {"list": []},
  "editable": true,
  "panels": [
    {"id": 1, "type": "timeseries", "title": "Weighted queue depth by stage", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "voicemesh_queue_depth", "legendFormat": "{{stage}} {{depth_unit}}"}], "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}},
    {"id": 2, "type": "timeseries", "title": "LLM to TTS queued speak-ahead", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "voicemesh_queue_depth{stage=\"llm_to_tts\",depth_unit=\"speak_ahead_ms\"}", "legendFormat": "queued speak-ahead ms"}, {"expr": "voicemesh_queue_items{stage=\"llm_to_tts\"}", "legendFormat": "debug items"}], "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}},
    {"id": 3, "type": "timeseries", "title": "TTS to Transport queued playable audio", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "voicemesh_queue_depth{stage=\"tts_to_transport\",depth_unit=\"audio_ms\"}", "legendFormat": "queued audio ms"}, {"expr": "voicemesh_queue_items{stage=\"tts_to_transport\"}", "legendFormat": "debug chunks"}], "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}},
    {"id": 4, "type": "timeseries", "title": "Cork, uncork, and hard-limit events", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum by (stage, transition, reason_code, depth_unit) (increase(voicemesh_backpressure_total[5m]))", "legendFormat": "{{stage}} {{transition}} {{reason_code}} {{depth_unit}}"}, {"expr": "sum by (stage, depth_unit, policy) (increase(voicemesh_backpressure_hard_limit_total[5m]))", "legendFormat": "{{stage}} hard_limit {{policy}} {{depth_unit}}"}], "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}},
    {"id": 5, "type": "timeseries", "title": "Cork duration p50 / p95 / p99", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "histogram_quantile(0.50, sum by (le, stage) (rate(voicemesh_backpressure_duration_seconds_bucket[5m])))", "legendFormat": "p50 {{stage}}"}, {"expr": "histogram_quantile(0.95, sum by (le, stage) (rate(voicemesh_backpressure_duration_seconds_bucket[5m])))", "legendFormat": "p95 {{stage}}"}, {"expr": "histogram_quantile(0.99, sum by (le, stage) (rate(voicemesh_backpressure_duration_seconds_bucket[5m])))", "legendFormat": "p99 {{stage}}"}], "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}},
    {"id": 6, "type": "table", "title": "Stage causing most corking", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "topk(5, sum by (stage) (increase(voicemesh_backpressure_total{transition=\"corked\"}[30m])))", "legendFormat": "{{stage}}"}], "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}},
    {"id": 7, "type": "timeseries", "title": "Stale chunks and stale audio dropped", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum by (stage, chunk_type, reason_code) (increase(voicemesh_stale_chunks_dropped_total[5m]))", "legendFormat": "{{stage}} {{chunk_type}} {{reason_code}}"}, {"expr": "sum by (stage, reason_code) (increase(voicemesh_stale_audio_dropped_ms_total[5m]))", "legendFormat": "{{stage}} audio_ms {{reason_code}}"}], "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}}
  ],
